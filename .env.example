# PostgreSQL Configuration
POSTGRES_USER=ethioqs
POSTGRES_PASSWORD=ethioqs_secret
POSTGRES_DB=ethioqs
POSTGRES_PORT=5432

# Application Configuration
# If running the backend on your host and DB in Docker, use 'localhost'
# If running both in the same Docker network (e.g. docker-compose), use 'db' as the hostname
DATABASE_URL=postgresql+asyncpg://ethioqs:ethioqs_secret@localhost:5432/ethioqs
SECRET_KEY=change_me_to_a_long_random_string
FRONTEND_URL=http://localhost:3000
